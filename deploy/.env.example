# Server .env for the Docker deploy (deploy/docker-compose.yml).
# Copy to the repo-root .env on the server and fill in real keys. NEVER commit .env.
#   cp deploy/.env.example .env

# Bybit credentials (required for LIVE; PAPER uses public market data only).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Bot launch mode for the container: PAPER (default) or LIVE.
# LIVE uses the real Bybit account, but the bot still boots to STANDBY and only
# trades after an explicit START command from the dashboard/API.
BOT_MODE=LIVE

# Infra — hostnames are the compose service names (internal ports).
DATABASE_URL=postgresql+asyncpg://quantbot:quantbot@postgres:5432/quantbot
REDIS_URL=redis://redis:6379/0
QUANTBOT_CONFIG=config/quantbot.yaml

# Backend API
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
# Same-origin via nginx, so CORS is not strictly needed; set your public origin if used.
CORS_ORIGINS=http://localhost:8090
API_AUTH_ENABLED=false
API_TOKEN_DEV=change-me
HEARTBEAT_ALIVE_SEC=15
API_RUN_MAINTENANCE=true
