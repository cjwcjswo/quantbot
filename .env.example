# Bybit API credentials (required for LIVE mode; PAPER uses public market data only)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Infrastructure (host ports match docker-compose.yml: 5433/6380 to avoid clashing
# with any pre-existing local Postgres/Redis on the default 5432/6379).
DATABASE_URL=postgresql+asyncpg://quantbot:quantbot@localhost:5433/quantbot
REDIS_URL=redis://localhost:6380/0

# Path to the YAML config file (defaults to config/quantbot.yaml)
QUANTBOT_CONFIG=config/quantbot.yaml

# Backend API token (used only when config/quantbot.yaml api.api_auth_enabled=true)
API_TOKEN_DEV=dev-token
