# Bybit API credentials (required for LIVE mode; PAPER uses public market data only)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Infrastructure
DATABASE_URL=postgresql+asyncpg://quantbot:quantbot@localhost:5432/quantbot
REDIS_URL=redis://localhost:6379/0

# Path to the YAML config file (defaults to config/quantbot.yaml)
QUANTBOT_CONFIG=config/quantbot.yaml

# --- Backend API (apps/api) ---
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_AUTH_ENABLED=false
API_TOKEN_DEV=dev-token
# Heartbeat freshness window (seconds) used to compute is_alive
HEARTBEAT_ALIVE_SEC=15
# Start the §25 maintenance scheduler inside the API process (set false to run separately)
API_RUN_MAINTENANCE=true
